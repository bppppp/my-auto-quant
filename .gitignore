# ============================================
# 敏感信息 (.env 含 LLM_API_KEY, 严禁提交)
# ============================================
.env
.env.local
.env.*.local
!.env.example

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
