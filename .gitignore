htmlcov/
.tox/
.nox/

# 虚拟环境
venv/
env/
.venv/
ENV/

# ============================================
# 数据目录 (8000+ CSV, 占 GB 级别, 外部获取)
# ============================================
data/
# 防御: 即使将来 data 放在别处, 这两类文件也忽略
*.csv
!strategies/**/*.csv
!subjects/**/*.csv

# ============================================
# 回测结果输出 (autoRun 生成)
# ============================================
result/

# ============================================
# autoRun 流水线运行时产物
# ============================================
autoRun/pipeline_state.json
autoRun/logs/
autoRun/.claude_fix_request.md
autoRun/.claude_fix_request.result.md
autoRun/.state_*.json.tmp

# ============================================
# strategies 系统日志
# ============================================
strategies/log/

# ============================================
# subjects/ 各策略运行时产物 (autoRun 生成, 每次跑都变)
# ============================================
subjects/*/log/
subjects/*/reportParams/
subjects/*/reportWeight/
subjects/*/strategiesParam/
subjects/*/strategiesWeight/

# ============================================
# 通用日志
# ============================================
*.log
logs/

