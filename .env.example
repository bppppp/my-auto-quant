# my-quant3 LLM 配置模板
# 复制为 .env 后填入真实值: cp .env.example .env
# .env 已加入 .gitignore, 不会提交

# ===== LLM 必填配置 =====
LLM_API_KEY=<your-api-key-here>
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M3
LLM_ENABLE_THINKING=adaptive

# DeepSeek V4 思考强度: low|medium|high|max (留空=走 API 默认)
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-pro
# LLM_REASONING_EFFORT=max
# LLM_ENABLE_THINKING=enabled
# LLM_ENABLE_THINKING=disabled

# ===== 推理参数 (可省略, 有默认值) =====
# LLM_TEMPERATURE=0.7
# LLM_TEMPERATURE_GENERATE=0.3
LLM_MAX_TOKENS=60000
LLM_TIMEOUT=360
# 思考模式: 直接传 thinking.type 的值, 不同 provider 取值不同
#   DeepSeek V4 → enabled (开) / disabled (关)
#   MiniMax     → adaptive (开) / disabled (关)   ← "enabled" 会被 API 拒 400
# 兼容旧值: 0/false/disabled = 关, 1/true/enabled = 开(用 "enabled")
# 留空 / 不设 → 用 LLM_THINKING_TYPE 兜底, 再不行根据代码默认


# ===== autoRun 流水线运行时参数 (可省略) =====
# PIPELINE_BATCH_SIZE=5
# PIPELINE_PARAMS_ROUNDS=20
# PIPELINE_WEIGHT_ROUNDS=20
# PIPELINE_TRANSLATE_MAX_ATTEMPTS=10
# PIPELINE_RESULT_DIR=result

# ===== 原有 strategies 系统运行时参数 (可省略) =====
# SELF_EVAL_MAX_RETRIES=20
# DEBOUNCE_SECONDS=5
# MAX_LISTEN_ITERATIONS=20
# MAX_REPORTS_REFERENCE=5
